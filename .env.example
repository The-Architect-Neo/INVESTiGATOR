# Copy this file to .env and fill in your values
# NEVER commit .env to git

# App
PORT=3000
NODE_ENV=development

# Canary alert webhook — Discord/Slack/email webhook URL for breach alerts
CANARY_WEBHOOK_URL=

# ──────────────────────────────────────────────────────────────────
# INVESTIGATOR API KEYS — all optional, route degrades gracefully
# ──────────────────────────────────────────────────────────────────

# Companies House — UK company registry (official gov API, free)
# Register: https://developer.company-information.service.gov.uk
COMPANIES_HOUSE_API_KEY=

# VirusTotal — domain/URL/IP reputation (free tier: 4/min, 500/day)
# Register: https://www.virustotal.com/gui/join-us
VIRUSTOTAL_API_KEY=

# IPinfo — IP geolocation / ASN (free tier: 50k req/mo without token)
# Register: https://ipinfo.io
IPINFO_TOKEN=

# Numverify — phone number validation (free tier: 100 req/mo)
# Register: https://numverify.com
NUMVERIFY_API_KEY=

# AbuseIPDB — community IP abuse reports (free tier: 1,000 checks/day)
# Register: https://www.abuseipdb.com/register
ABUSEIPDB_API_KEY=

# URLscan.io — URL analysis and screenshot (free tier: 5,000 scans/day)
# Register: https://urlscan.io/user/signup
URLSCAN_API_KEY=

# PhishTank — phishing URL database (no key required; key increases rate limits)
# Register: https://www.phishtank.com/register.php
PHISHTANK_API_KEY=

# Charity Commission — UK registered charities (no key required for basic search)
# Register: https://register-of-charities.charitycommission.gov.uk/register/api
CHARITY_COMMISSION_KEY=

# Have I Been Pwned — email breach lookup (paid, £3.50/mo)
# Register: https://haveibeenpwned.com/API/Key
# Without this key: email type still works (disposable check + MX + domain intel)
HIBP_API_KEY=
